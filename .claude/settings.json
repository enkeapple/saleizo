{
  "env": {
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "Bash(pnpm run start:*)",
      "Bash(pnpm run lint:*)",
      "Bash(pnpm run android:*)",
      "Bash(pnpm run watchman:clean:*)",
      "Bash(pnpm run android:clean:*)",
      "Bash(pnpm run node:clean:*)",
      "Bash(pnpm run ports:kill:*)",
      "Bash(pnpm run config:clean:*)",
      "Bash(pnpm run postinstall:*)",
      "Bash(pnpm run version:name:*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/security-guard.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/bash-read-guard.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/read-guard.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/edit-write-guard.sh"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "callstack-agent-skills": {
      "source": {
        "source": "github",
        "repo": "callstackincubator/agent-skills"
      },
      "autoUpdate": true
    },
    "swmansion": {
      "source": {
        "source": "github",
        "repo": "software-mansion-labs/skills"
      },
      "autoUpdate": true
    },
    "obilyk-skills": {
      "source": {
        "source": "github",
        "repo": "enkeapple/obilyk-skills"
      },
      "autoUpdate": true
    }
  },
  "enabledPlugins": {
    "react-native-best-practices@callstack-agent-skills": true,
    "upgrading-react-native@callstack-agent-skills": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "skills@swmansion": false
  },
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
